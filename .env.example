# 微信智能浇水上报系统 - 环境变量配置
# WeChat Smart Watering Reporting System - Environment Variables

# ============================================================
# 应用配置
# ============================================================
APP_NAME="微信智能浇水上报系统"
APP_VERSION="1.0.0"
DEBUG=true
HOST=0.0.0.0
PORT=8000

# 配置文件路径
CONFIG_PATH=./config.yaml

# ============================================================
# 数据库配置
# ============================================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=watering_user
DB_PASSWORD=your_password
DB_NAME=watering_db
DB_CHARSET=utf8mb4

# ============================================================
# 本地状态存储配置
# ============================================================
STATE_PENDING_TIMEOUT=300
STATE_USER_STATE_TTL=3600

# ============================================================
# 微信配置
# ============================================================
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret
WECHAT_TOKEN=your_wechat_token
WECHAT_ENCODING_AES_KEY=your_encoding_aes_key

# ============================================================
# 大模型配置
# ============================================================
LLM_PROVIDER=zhipuai  # openai, zhipuai, qwen, deepseek

# OpenAI配置
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 智谱GLM配置
ZHIPUAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# 通义千问配置
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxx
QWEN_MODEL=qwen-turbo

# DeepSeek配置
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
