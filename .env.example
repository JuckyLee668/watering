# App
APP_NAME=微信智能浇水上报系统
APP_VERSION=1.0.0
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
CONFIG_PATH=./config.yaml

# Database
DB_URL=
DB_DRIVER=sqlite
DB_SQLITE_PATH=data/watering.db
DB_FALLBACK_TO_SQLITE=false
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=
DB_PASSWORD=
DB_NAME=
DB_CHARSET=utf8mb4
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_PRE_PING=true

# State
STATE_PENDING_TIMEOUT=300
STATE_USER_STATE_TTL=3600

# WeChat
# Fill these first: they are required before startup and WeChat callback verification.
WECHAT_APP_ID=your_app_id
WECHAT_APP_SECRET=your_app_secret
WECHAT_TOKEN=your_wechat_token
WECHAT_ENCODING_AES_KEY=your_encoding_aes_key
WECHAT_CALLBACK_URL=/wechat/callback
WECHAT_WELCOME_MESSAGE=您好！欢迎使用智能浇水上报系统。请直接输入浇水信息，例如：今天下午2点到4点给3号地浇了50方水。

# LLM
# Recommended: only fill this generic group for the provider you are using.
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=500

# Optional legacy provider-specific fields, kept for backward compatibility.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=500
ZHIPUAI_API_KEY=
QWEN_API_KEY=
QWEN_MODEL=qwen-turbo
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Plots / logging / CORS
PLOTS_ENABLED=true
PLOTS_CSV_PATH=data/plots_sample.csv
LOG_LEVEL=INFO
LOG_FORMAT=<green>{time:YYYY-MM-DD HH:mm:ss}</green> | <level>{level: <8}</level> | <cyan>{name}</cyan>:<cyan>{function}</cyan>:<cyan>{line}</cyan> - <level>{message}</level>
LOG_FILE=logs/app.log
LOG_ROTATION=100 MB
LOG_RETENTION=30 days
LOG_COMPRESSION=zip
CORS_ENABLED=true
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
